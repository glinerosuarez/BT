JOB_HUNTER_DB_PATH=job_hunter.db
JOB_HUNTER_POLL_INTERVAL_MINUTES=15
JOB_HUNTER_REQUEST_TIMEOUT_SECONDS=20

JOB_HUNTER_SOURCE_ARBEITNOW=true
JOB_HUNTER_SOURCE_REMOTIVE=true
JOB_HUNTER_SOURCE_THEMUSE=true
JOB_HUNTER_SOURCE_GREENHOUSE=true
JOB_HUNTER_SOURCE_LEVER=true
JOB_HUNTER_SOURCE_RSS=true
JOB_HUNTER_SOURCE_GITHUB_REPOS=false
JOB_HUNTER_SOURCE_ASHBY=true
JOB_HUNTER_SOURCE_HANDSHAKE=false
JOB_HUNTER_SOURCE_USAJOBS=false
JOB_HUNTER_SOURCE_ADZUNA=false
JOB_HUNTER_GREENHOUSE_TOKEN_FILE=job_hunter/data/greenhouse_tokens.txt
JOB_HUNTER_LEVER_TOKEN_FILE=job_hunter/data/lever_tokens.txt
JOB_HUNTER_RSS_FEED_FILE=job_hunter/data/rss_feeds.txt
JOB_HUNTER_GREENHOUSE_QUARANTINE_FILE=job_hunter/data/greenhouse_tokens.quarantine.txt
JOB_HUNTER_LEVER_QUARANTINE_FILE=job_hunter/data/lever_tokens.quarantine.txt
JOB_HUNTER_RSS_QUARANTINE_FILE=job_hunter/data/rss_feeds.quarantine.txt
JOB_HUNTER_SOURCE_FAILURE_QUARANTINE_THRESHOLD=2
JOB_HUNTER_SOURCE_RESTORE_SUCCESS_THRESHOLD=2
JOB_HUNTER_SOURCE_PROBE_LIMIT_PER_RUN=5

JOB_HUNTER_MIN_RELEVANCE_SCORE=3.0
JOB_HUNTER_MIN_ELIGIBILITY_CONFIDENCE=0.4
JOB_HUNTER_NOTIFY_AMBIGUOUS=true
JOB_HUNTER_MAX_POSTING_AGE_DAYS=7
JOB_HUNTER_THEMUSE_PAGES=2
JOB_HUNTER_GREENHOUSE_BOARDS=airbnb,databricks,discord,stripe
JOB_HUNTER_LEVER_COMPANIES=atlassian,lever,plaid
JOB_HUNTER_RSS_FEEDS=https://remoteok.com/remote-internship-jobs.rss,https://weworkremotely.com/categories/remote-programming-jobs.rss
JOB_HUNTER_GITHUB_REPO_READMES=https://raw.githubusercontent.com/vanshb03/Summer2027-Internships/dev/README.md
JOB_HUNTER_ASHBY_BOARDS=Etched,apex-technology-inc,homebase
JOB_HUNTER_HANDSHAKE_SEARCH_URLS=
# Example:
# Prefer narrower Handshake queries over broad ones like `data` or `data science`.
# JOB_HUNTER_HANDSHAKE_SEARCH_URLS="https://app.joinhandshake.com/job-search/...query=machine%20learning...,https://app.joinhandshake.com/job-search/...query=data%20engineer%20intern..."
JOB_HUNTER_HANDSHAKE_PROFILE_DIR=.handshake-profile
JOB_HUNTER_HANDSHAKE_HEADLESS=true
JOB_HUNTER_HANDSHAKE_MAX_RESULTS=25
JOB_HUNTER_HANDSHAKE_PAGE_TIMEOUT_SECONDS=30
JOB_HUNTER_TITLE_BLACKLIST_PATTERNS=\\brecruiter\\b,\\brecruiting\\b,\\btalent\\b,\\bhuman resources\\b,\\bhr\\b,\\bpeople operations\\b,\\bmanager\\b,\\bdirector\\b
JOB_HUNTER_DATA_ROLE_TITLE_PATTERNS=\\b(machine learning|ml)\\b,\\bdata (science|scientist)\\b,\\bdata engineer(ing)?\\b,\\banalytics engineer\\b,\\b(applied|research) scientist\\b,\\bquant(itative)?\\b
JOB_HUNTER_NON_DATA_TITLE_PATTERNS=\\bdeveloper advocacy\\b,\\bgo[- ]to[- ]market\\b,\\b(content|video content|editorial)\\b,\\b(sales|marketing|partnerships?)\\b,\\bcustomer success\\b
JOB_HUNTER_POLICY_REJECT_PATTERNS=\\bph\\.?d\\.?\\b,\\bdoctoral\\b,\\beconomics team\\b,\\boperations research\\b
JOB_HUNTER_MIN_DATA_SIGNAL_COUNT=2

JOB_HUNTER_USAJOBS_USER_AGENT=
JOB_HUNTER_USAJOBS_AUTH_KEY=
JOB_HUNTER_USAJOBS_RESULTS_PER_PAGE=250

JOB_HUNTER_ADZUNA_APP_ID=
JOB_HUNTER_ADZUNA_APP_KEY=
JOB_HUNTER_ADZUNA_COUNTRY=us
JOB_HUNTER_ADZUNA_PAGES=2

JOB_HUNTER_TELEGRAM_BOT_TOKEN=
JOB_HUNTER_TELEGRAM_CHAT_ID=
